# Postgres connection string from your Neon project (Dashboard -> Connect).
# Use the "pooled" connection string for the app at runtime.
DATABASE_URL=

# Auth.js session encryption secret. Generate with: npx auth secret
AUTH_SECRET=

# Optional - only needed to actually send confirmation/cancellation emails.
# Without it, the app logs what it would have sent instead of sending it.
RESEND_API_KEY=
EMAIL_FROM="Bookings <onboarding@resend.dev>"

# Single clinic-wide timezone (IANA name) used to interpret doctors' hours.
NEXT_PUBLIC_CLINIC_TIMEZONE=America/New_York

# Public base URL, used to build links in emails (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Used once by `npm run db:seed` to create the initial admin + demo doctor logins.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_DOCTOR_EMAIL=doctor@example.com
SEED_DOCTOR_PASSWORD=ChangeMe123!
